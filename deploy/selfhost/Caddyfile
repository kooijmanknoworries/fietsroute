# SITE_ADDRESS comes from docker-compose.yml:
#   DOMAIN empty  -> ":80"                     -> plain HTTP (LAN / by IP)
#   DOMAIN set    -> "thuis.nicokooijman.nl"   -> automatic HTTPS via
#                    Let's Encrypt (port 80 auto-redirects to 443)
{$SITE_ADDRESS} {
        encode gzip
        # Dutch text-to-speech (Piper) for turn-by-turn voice guidance. Same
        # origin as the app, so the browser calls it with no CORS/mixed-content.
        # handle_path strips /voice, so /voice/tts -> piper-tts:8020/tts.
        handle_path /voice/* {
                reverse_proxy piper-tts:8020
        }
        reverse_proxy web:8080
}

# LAN access by internal IP over plain HTTP (public CAs cannot issue
# certificates for private IPs). Keeps the web app reachable at
# http://192.168.3.71 alongside the public HTTPS domain above.
http://192.168.3.71 {
        encode gzip
        handle_path /voice/* {
                reverse_proxy piper-tts:8020
        }
        reverse_proxy web:8080
}
