# Fietsrouteplanner self-host configuration.
# Copy to .env in this directory and fill in the values:
#   cp .env.example .env

# ── Database ────────────────────────────────────────────────────────────────
# Postgres runs inside the stack with a persistent Docker volume (pgdata).
POSTGRES_USER=fietsroute
POSTGRES_DB=fietsroute
# REQUIRED — pick a strong password (only used inside the Docker network).
# Note: you never set DATABASE_URL yourself — docker-compose.yml builds it
# from the POSTGRES_* values above and passes it to the api-server/migrate.
POSTGRES_PASSWORD=

# ── Clerk authentication ────────────────────────────────────────────────────
# From your Clerk application (https://dashboard.clerk.com → API keys).
# REQUIRED.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk frontend-API proxy path.
#   Leave EMPTY  when using a Clerk DEVELOPMENT instance (pk_test_...):
#                the apps talk directly to *.clerk.accounts.dev.
#   Set to /api/__clerk  when using a Clerk PRODUCTION instance (pk_live_...)
#                bound to your custom domain (requires DOMAIN below).
# Changing this requires a rebuild: docker compose build web mobile
CLERK_PROXY_URL=

# ── Public address ──────────────────────────────────────────────────────────
# REQUIRED — the host (no protocol!) riders use to reach the stack. This is
# BAKED INTO the mobile app bundles at build time; changing it requires
# `docker compose build mobile` (and `web` if CLERK_PROXY_URL changed).
#   LAN only:       the machine's LAN IP, e.g. 192.168.1.50
#   Custom domain:  the same value as DOMAIN below, e.g. fiets.example.com
PUBLIC_DOMAIN=

# Custom domain for automatic HTTPS (Let's Encrypt via Caddy).
#   Leave EMPTY to serve plain HTTP on port 80 (LAN / by IP).
#   Set to your domain (e.g. fiets.example.com) once its DNS A record points
#   at your static IP and ports 80+443 are forwarded to this machine.
# NOTE: the mobile app requires HTTPS — it only fully works once DOMAIN is set.
DOMAIN=

# Host ports Caddy binds (change if 80/443 are taken on this machine).
HTTP_PORT=80
HTTPS_PORT=443

# ── Optional ────────────────────────────────────────────────────────────────
# API log level (pino): trace|debug|info|warn|error
LOG_LEVEL=info
# Set to any value to skip the NL/BE cycling-network preload on API start
# (first preload takes a while and fills the database; normally leave empty).
DISABLE_NETWORK_PRELOAD=
